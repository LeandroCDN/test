# Polymarket private key (without 0x prefix)
# Export from MetaMask: Account Details -> Export Private Key
PK=your_private_key_here

# Signature type:
#   0 = EOA / MetaMask / hardware wallet (default)
#   1 = Email / Magic wallet
#   2 = Browser wallet proxy
SIGNATURE_TYPE=0

# (Optional) Funder address - only needed for Magic/proxy wallets
# FUNDER=0xYourFunderAddress
